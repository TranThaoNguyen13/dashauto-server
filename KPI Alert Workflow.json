          "conditions": [
            {
              "id": "d00f5f4c-39c7-4926-b277-863c6cc8068f",
              "leftValue": "={{$json.alert_count}}",
              "rightValue": 0,
              "operator": {
                "type": "number",
                "operation": "gt"
              }
