    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\n\nconst revenueThreshold = 999999999;\nconst openAlertsThreshold = 4;\n\nlet alerts = [];\n\nif (Number(data.totalRevenue) < revenueThreshold) {\n  alerts.push({\n    type: \"revenue\",\n    message: `Doanh thu thấp: ${data.totalRevenue} < ${revenueThreshold}`,\n    severity: \"high\"\n  });\n}\n\nif (Number(data.openAlerts) > openAlertsThreshold) {\n  alerts.push({\n    type: \"system\",\n    message: `Số cảnh báo mở cao: ${data.openAlerts} > ${openAlertsThreshold}`,\n    severity: \"medium\"\n  });\n}\n\nreturn [\n  {\n    json: {\n      ...data,\n      alert_count: alerts.length,\n      alerts\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        624,
        0
      ],
      "id": "c8f29827-1994-4108-97cc-466a1edbeb19",
      "name": "Check Alert"
    },
