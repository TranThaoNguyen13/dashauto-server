      "id": "10713ecc-627b-47c3-b24e-68a19f18d3fc",
      "name": "Has Alert?"
    },
    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\n\nconst detail = data.alerts.map((a, i) => {\n  return `${i + 1}. ${a.message}`;\n}).join('\\n');\n\nreturn [\n  {\n    json: {\n      ...data,\n      final_message:\n`[CANH BAO KPI]\nDoanh thu: ${data.totalRevenue}\nSo don: ${data.totalOrders}\nSo canh bao dang mo: ${data.openAlerts}\n\nChi tiet:\n${detail}`\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
